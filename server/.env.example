# ======================
# Database (Supabase Postgres)
# ======================

# Connection via pooler (recommended for app)
# Port 6543 = connection pooling
DATABASE_URL=postgresql://postgres:your_password@db.your-project-id.supabase.co:6543/postgres?pgbouncer=true

# Direct connection (for migrations, Prisma, scripts)
# Port 5432 = direct connection
DIRECT_URL=postgresql://postgres:your_password@db.your-project-id.supabase.co:5432/postgres


# ======================
# Supabase
# ======================

# Project URL (Dashboard → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Service role key (SECRET — backend only!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Storage bucket name
SUPABASE_STORAGE_BUCKET=recipes_assets


# ======================
# Authentication (JWT)
# ======================

# Access token
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d


# ======================
# OAuth (Google)
# ======================

# Example: 1234567890-abc.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com


# ======================
# External APIs
# ======================

# USDA FoodData Central API key
USDA_API_KEY=your_usda_api_key_here